#!/bin/sh

if [ $(xrandr --query | rg -i screen | wc -l) = 2 ]; then
    xrandr --output HDMI-1 --mode 1920x1080 --pos 1920x0 --rotate normal --output DVI-I-1 --primary --mode 1920x1080 --pos 0x0 --rotate normal
fi

[ -f ~/.config/xmodmap/Xmodmap ] && xmodmap ~/.config/xmodmap/Xmodmap
sxhkd &

#Lines following an exec are ignored so place this last
session=exec bspwm -c $XDG_CONFIG_HOME/bspwm/bspwmrc
